# API settings
PORT=3000

# Database settings for local development
DATABASE_URL="postgresql://postgres:postgres@localhost:5454/tech_challenge_blog?schema=public"

# PostgreSQL Container settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tech_challenge_blog

# JWT settings (REQUIRED - must be at least 32 characters)
JWT_SECRET=your-secret-key-at-least-32-characters-long
JWT_EXPIRES_IN=7d
